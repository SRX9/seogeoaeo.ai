{
  "version": "claudia-kernel-eval-v1",
  "threshold": 1,
  "scenarios": [
    {
      "id": "select-research-when-draft-expensive",
      "kind": "selection",
      "remainingCredits": 80,
      "availableTools": ["research.refresh", "article.draft", "visibility.audit.execute"],
      "impacts": { "research": 0.7, "draft": 1, "audit": 0.4 },
      "expected": "execute:research"
    },
    {
      "id": "select-draft-for-grounded-page-objective",
      "kind": "selection",
      "remainingCredits": 500,
      "availableTools": ["research.refresh", "article.draft", "visibility.audit.execute"],
      "impacts": { "research": 0.2, "draft": 1, "audit": 0.15 },
      "expected": "execute:draft"
    },
    {
      "id": "select-audit-for-critical-finding-objective",
      "kind": "selection",
      "remainingCredits": 500,
      "availableTools": ["research.refresh", "article.draft", "visibility.audit.execute"],
      "impacts": { "research": 0.1, "draft": 0.05, "audit": 1 },
      "expected": "execute:audit"
    },
    {
      "id": "budget-exhaustion-escalates",
