{
  "name": "seo-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "node scripts/build-cloudflare.mjs",
    "preview:cf": "pnpm run build:cf && opennextjs-cloudflare preview",
    "deploy:cf": "node scripts/deploy-cloudflare.mjs",
    "secrets:cf": "node scripts/set-worker-secrets.mjs",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "webhook": "pnpm dlx ngrok http --url=relaxed-sadly-cardinal.ngrok-free.app 3000"
  },
  "dependencies": {
    "@heroui-pro/react": "^1.0.0-beta.6",
    "@heroui/react": "^3.2.1",
    "@heroui/styles": "^3.2.1",
    "@number-flow/react": "^0.6.0",
    "@opennextjs/cloudflare": "^1.3.0",
    "@tanstack/react-query": "^5.101.1",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/extensions": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@tiptap/suggestion": "^3.27.1",
    "better-auth": "^1.6.18",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.2",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "marked": "^18.0.5",
    "motion": "^12.40.0",
    "next": "^15.3.4",
    "postgres": "^3.4.7",
    "react": "^19.1.0",
    "react-aria-components": "^1.19.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.2.0",
    "streamdown": "^2.5.0",
    "stripe": "^22.2.1",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.2.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.10",
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.29.0",
    "eslint-config-next": "^15.3.4",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.20.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@heroui-pro/react",
      "esbuild",
      "sharp",
      "workerd",
      "unrs-resolver"
    ]
