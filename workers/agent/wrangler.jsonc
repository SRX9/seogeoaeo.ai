{
	"$schema": "../../node_modules/wrangler/config-schema.json",
	"name": "agent-workflow",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-05",
	"workflows": [
		{
			"name": "daily-content-agent",
			"binding": "AGENT_WORKFLOW",
			"class_name": "DailyBrandWorkflow"
		},
		{
			"name": "setup-run",
			"binding": "SETUP_WORKFLOW",
			"class_name": "SetupRunWorkflow"
		},
		{
			"name": "audit-run",
			"binding": "AUDIT_WORKFLOW",
			"class_name": "AuditRunWorkflow"
		},
		{
			"name": "connector-mutation",
			"binding": "MUTATION_WORKFLOW",
			"class_name": "ConnectorMutationWorkflow"
		}
	],
	"send_email": [
		{
			"name": "EMAIL"
		}
	],
	"services": [
		{
			"binding": "APP",
			"service": "seo-ai"
		}
	],
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 1,
			"invocation_logs": true,
			"persist": true,
			// Same destination as seo-ai (Cloudflare account-level Observability destination).
			"destinations": ["posthog-logs"]
		},
		"traces": {
			"enabled": true,
			"head_sampling_rate": 1,
			"persist": true
		}
	},
	"vars": {
		// Origin of the Next.js app the Workflow calls back into. Override per-env at
		// deploy time; CRON_SECRET is a secret (wrangler secret put CRON_SECRET).
		"APP_ORIGIN": "https://seogeoaeo.ai"
	}
}
